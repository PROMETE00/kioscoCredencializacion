#--------------------------------------------------------------------
# Production Environment Configuration
#
# ⚠️ IMPORTANT: Review and update ALL values before deploying
# Never commit this file with real credentials
#--------------------------------------------------------------------

#--------------------------------------------------------------------
# ENVIRONMENT
#--------------------------------------------------------------------

CI_ENVIRONMENT = production

#--------------------------------------------------------------------
# APP
#--------------------------------------------------------------------

# ⚠️ CHANGE THIS: Set your actual domain (provided by Cloudflare Tunnel)
app.baseURL = 'https://your-tunnel-domain.trycloudflare.com/'

# Force HTTPS in production
app.forceGlobalSecureRequests = true

# Enable Content Security Policy
app.CSPEnabled = true

#--------------------------------------------------------------------
# DATABASE
#--------------------------------------------------------------------
# ⚠️ CHANGE THESE: Use strong, unique passwords

database.default.hostname = db
database.default.database = kiosco_production
database.default.username = kiosco_prod_user
database.default.password = CHANGE_THIS_DB_PASSWORD_MIN_32_CHARS
database.default.DBDriver = MySQLi
database.default.DBPrefix =
database.default.port = 3306

#--------------------------------------------------------------------
# MYSQL ROOT PASSWORD
#--------------------------------------------------------------------
# ⚠️ CHANGE THIS: Used in docker-compose for MySQL root user
MYSQL_ROOT_PASSWORD = CHANGE_THIS_ROOT_PASSWORD_MIN_32_CHARS

#--------------------------------------------------------------------
# CLOUDFLARE TUNNEL
#--------------------------------------------------------------------
# ⚠️ REQUIRED: Get your tunnel token from Cloudflare Zero Trust Dashboard
# Instructions:
# 1. Go to https://one.dash.cloudflare.com/
# 2. Navigate to Networks > Tunnels
# 3. Create a new tunnel or use existing one
# 4. Copy the token from the tunnel configuration
# 5. Paste it here
CLOUDFLARE_TUNNEL_TOKEN = eyJhIjoiWU9VUl9UT0tFTl9IRVJFIn0

#--------------------------------------------------------------------
# SEEDERS - Default Passwords for Initial Setup
#--------------------------------------------------------------------
# ⚠️ CHANGE THESE: Strong passwords for initial user accounts
# These are only used when running seeders for the first time
SEED_DEFAULT_PASSWORD = ChangeThisStationPassword123!
SEED_ADMIN_PASSWORD = ChangeThisAdminPassword123!

#--------------------------------------------------------------------
# ENCRYPTION
#--------------------------------------------------------------------
# ⚠️ REQUIRED: Generate with: php spark key:generate
# Run this command to generate a secure encryption key
encryption.key = 

#--------------------------------------------------------------------
# SESSION
#--------------------------------------------------------------------

session.driver = 'CodeIgniter\Session\Handlers\DatabaseHandler'
session.cookieName = 'kiosco_session'
session.expiration = 7200
session.savePath = 'ci_sessions'
session.matchIP = false
session.timeToUpdate = 300
session.regenerateDestroy = true

#--------------------------------------------------------------------
# COOKIE
#--------------------------------------------------------------------

cookie.prefix = 'kiosco_'
cookie.httponly = true
cookie.secure = true
cookie.samesite = 'Lax'

#--------------------------------------------------------------------
# SECURITY
#--------------------------------------------------------------------

# Disable sensitive headers in production
security.csrfProtection = 'session'
security.tokenRandomize = true
security.tokenName = 'csrf_token_kiosco'
security.headerName = 'X-CSRF-TOKEN'
security.cookieName = 'csrf_cookie_kiosco'
security.expires = 7200
security.regenerate = true

#--------------------------------------------------------------------
# LOGGER
#--------------------------------------------------------------------

logger.threshold = 4

#--------------------------------------------------------------------
# ADDITIONAL PRODUCTION SETTINGS
#--------------------------------------------------------------------

# Disable debug toolbar in production
toolbar.enabled = false

# Error handling
app.showPHPErrors = false
